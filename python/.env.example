# Copy to .env and adjust as needed.
# docker-compose.yml picks these up automatically.

EZRA_PORT=42002
EZRA_QUEUE=tasks
TASK_COUNT=50
IDLE_TIMEOUT=30

# immediate: nack with xdel, task retries right away (default)
# deferred:  skip nack, EZRA reclaims after visibility_timeout seconds
NACK_MODE=immediate
